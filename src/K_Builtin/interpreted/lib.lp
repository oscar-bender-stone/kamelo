symbol size_LIST : ╬┤ SortList Рєњ ╬┤ SortInt;

symbol fillList_LIST : ╬┤ SortList Рєњ ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortKItem Рєњ ╬┤ SortList;

