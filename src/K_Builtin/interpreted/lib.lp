symbol bitRangeInt : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortInt;
rule bitRangeInt $I $IDX $LEN Рєф _modInt_ (_>>Int_ $I $IDX) (_<<Int_ 1 $LEN);

symbol signExtendBitRangeInt : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortInt;
rule signExtendBitRangeInt $I $IDX $LEN Рєф _-Int_ (_modInt_ (_PlusInt_ (bitRangeInt $I $IDX $LEN) (_<<Int_ 1 (_-Int_ $LEN 1))) (_<<Int_ 1 $LEN)) (_<<Int_ 1 (_-Int_ $LEN 1));



