
// Translation of the module BASIC-K
symbol SortK : TYPE;
symbol SortKItem : SortK;

// Our injection between K and Dedukti
injective symbol ╬┤ : SortK Рєњ TYPE;

// Translation of the module INJ
symbol inj [From To : SortK] : ╬┤ From Рєњ ╬┤ To;

// Some builtins for Lambdapi
symbol Prop : TYPE;
symbol P : Prop Рєњ TYPE;
builtin "Prop" РЅћ Prop;
builtin "P" РЅћ P;

// BOOLEAN

symbol SortBool : SortK;
symbol true : ╬┤ SortBool;
symbol false : ╬┤ SortBool;

symbol notBool_ : ╬┤ SortBool Рєњ ╬┤ SortBool;
rule notBool_ true Рєф false;
rule notBool_ false Рєф true;

symbol _andBool_ : ╬┤ SortBool Рєњ ╬┤ SortBool Рєњ ╬┤ SortBool;
rule _andBool_ true  $B    Рєф $B;
rule _andBool_ _     false Рєф false;
rule _andBool_ $B    true  Рєф $B;
rule _andBool_ false _     Рєф false;

symbol _andThenBool_ : ╬┤ SortBool Рєњ ╬┤ SortBool Рєњ ╬┤ SortBool;
rule _andThenBool_ true  $K    Рєф $K;
rule _andThenBool_ _     false Рєф false;
rule _andThenBool_ $K    true  Рєф $K;
rule _andThenBool_ false _     Рєф false;

symbol _impliesBool_ : ╬┤ SortBool Рєњ ╬┤ SortBool Рєњ ╬┤ SortBool;
rule _impliesBool_ true  $B    Рєф $B;
rule _impliesBool_ false _     Рєф true;
rule _impliesBool_ _     true  Рєф true;
rule _impliesBool_ $B    false Рєф notBool_ $B;

symbol _orBool_ : ╬┤ SortBool Рєњ ╬┤ SortBool Рєњ ╬┤ SortBool;
rule _orBool_ true  _     Рєф true;
rule _orBool_ false $B    Рєф $B;
rule _orBool_ _     true  Рєф true;
rule _orBool_ $B    false Рєф $B;

symbol _orElseBool_ : ╬┤ SortBool Рєњ ╬┤ SortBool Рєњ ╬┤ SortBool;
rule _orElseBool_ true  _     Рєф true;
rule _orElseBool_ false $K    Рєф $K;
rule _orElseBool_ _     true  Рєф true;
rule _orElseBool_ $K    false Рєф $K;

symbol _xorBool_ : ╬┤ SortBool Рєњ ╬┤ SortBool Рєњ ╬┤ SortBool;
rule _xorBool_ false $B    Рєф $B;
rule _xorBool_ $B    false Рєф $B;
rule _xorBool_ $B    $B    Рєф false;

symbol _==Bool_ : ╬┤ SortBool Рєњ ╬┤ SortBool Рєњ ╬┤ SortBool;
rule _==Bool_ false false Рєф true;
rule _==Bool_ true  true  Рєф true;
rule _==Bool_ false true  Рєф false;
rule _==Bool_ true  false Рєф false;

symbol _=Slsh=Bool_ : ╬┤ SortBool Рєњ ╬┤ SortBool Рєњ ╬┤ SortBool;
rule _=Slsh=Bool_ $B1 $B2 Рєф notBool_ (_==Bool_ $B1 $B2);


// Interlude

// For Viry encoding
symbol РЎГBool : SortK;
symbol РЎГ : ╬┤ РЎГBool;
symbol РЎГinj : ╬┤ SortBool Рєњ ╬┤ РЎГBool;

symbol _==K_ : SortK Рєњ SortK Рєњ ╬┤ SortBool; // TODO
// rule _==K_ (kseq (inj [SortBool] [SortKItem] $K1) dotk) (kseq (inj [SortBool] [SortKItem] $K2) dotk) Рєф _==Bool_ $K1 $K2;
// rule _==K_ (kseq (inj [SortInt] [SortKItem] $I1) dotk) (kseq (inj [SortInt] [SortKItem] $I2) dotk) Рєф _==Int_ $I1 $I2;

symbol _=Slsh=K_ : SortK Рєњ SortK Рєњ ╬┤ SortBool;
rule _=Slsh=K_ $K1 $K2 Рєф notBool_ (_==K_ $K1 $K2);


// INT

symbol SortInt : SortK; // TODO Fix
symbol zero : ╬┤ SortInt;
symbol succ : ╬┤ SortInt Рєњ ╬┤ SortInt;

builtin "0" РЅћ zero;
builtin "+1" РЅћ succ;

symbol _<Int_ : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortBool;
rule _<Int_ 0 0 Рєф false;
rule _<Int_ 0 (succ _) Рєф true;
rule _<Int_ (succ $m) (succ $n) Рєф _<Int_ $m $n;
rule _<Int_ (succ _) 0 Рєф false;

symbol _>=Int_ : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortBool;
rule _>=Int_ 0 0 Рєф true;
rule _>=Int_ 0 (succ _) Рєф false;
rule _>=Int_ (succ $m) (succ $n) Рєф _>=Int_ $m $n;
rule _>=Int_ (succ _) 0 Рєф true;

symbol _>Int_ : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortBool;
rule _>Int_ 0 0 Рєф false;
rule _>Int_ 0 (succ _) Рєф false;
rule _>Int_ (succ $m) (succ $n) Рєф _>Int_ $m $n;
rule _>Int_ (succ _) 0 Рєф true;

symbol _<=Int_ : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortBool;
rule _<=Int_ 0 0 Рєф true;
rule _<=Int_ 0 (succ _) Рєф true;
rule _<=Int_ (succ $m) (succ $n) Рєф _<=Int_ $m $n;
rule _<=Int_ (succ _) 0 Рєф false;

symbol _==Int_ : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortBool;
rule _==Int_ 0 0 Рєф true;
rule _==Int_ 0 (succ _) Рєф false;
rule _==Int_ (succ $m) (succ $n) Рєф _==Int_ $m $n;
rule _==Int_ (succ _) 0 Рєф false;

symbol _=Slsh=Int_ : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortBool;
rule _=Slsh=Int_ $I1 $I2 Рєф notBool_ (_==Int_ $I1 $I2);

symbol _-Int_ : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortInt;
rule _-Int_ 0 0 Рєф 0;
rule _-Int_ 0 (succ _) Рєф 0;
rule _-Int_ (succ $m) (succ $n) Рєф _-Int_ $m $n;
rule _-Int_ (succ $n) 0 Рєф succ $n;

symbol _PlusInt_ : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortInt;
rule _PlusInt_ (succ $m) $n Рєф succ (_PlusInt_ $m $n);
rule _PlusInt_ 0 $n Рєф $n;

symbol _*Int_ : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortInt;
rule _*Int_ (succ $m) $n Рєф _PlusInt_ $n (_*Int_ $m $n);
rule _*Int_ 0 $n Рєф 0;

symbol minInt : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortInt;
symbol РЎГminInt : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ РЎГBool Рєњ ╬┤ РЎГBool Рєњ ╬┤ SortInt;
rule minInt $x1 $x2 Рєф РЎГminInt $x1 $x2 РЎГ РЎГ;
rule РЎГminInt $I1 $I2 (РЎГinj true) _ Рєф $I1;
rule РЎГminInt $I1 $I2 РЎГ $y0 Рєф РЎГminInt $I1 $I2 (РЎГinj (_<=Int_ $I1 $I2)) $y0;
rule РЎГminInt $I1 $I2 _ (РЎГinj true) Рєф $I2;
rule РЎГminInt $I1 $I2 $y1 РЎГ Рєф РЎГminInt $I1 $I2 $y1 (РЎГinj (_>=Int_ $I1 $I2));

symbol maxInt : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortInt;
symbol РЎГmaxInt : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ РЎГBool Рєњ ╬┤ РЎГBool Рєњ ╬┤ SortInt;
rule maxInt $x1 $x2 Рєф РЎГmaxInt $x1 $x2 РЎГ РЎГ;
rule РЎГmaxInt $I1 $I2 (РЎГinj true) _ Рєф $I2;
rule РЎГmaxInt $I1 $I2 РЎГ $y0 Рєф РЎГmaxInt $I1 $I2 (РЎГinj (_<=Int_ $I1 $I2)) $y0;
rule РЎГmaxInt $I1 $I2 _ (РЎГinj true) Рєф $I1;
rule РЎГmaxInt $I1 $I2 $y1 РЎГ Рєф РЎГmaxInt $I1 $I2 $y1 (РЎГinj (_>=Int_ $I1 $I2));


symbol _<<Int_ : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortInt; // TODO

symbol _>>Int_ : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortInt; // TODO

symbol ~Int_ : ╬┤ SortInt Рєњ ╬┤ SortInt; // TODO

symbol _SlshInt_ : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortInt; // TODO

symbol _Xor-%Int__ : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortInt; // TODO

symbol _Xor-Int_ : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortInt; // TODO

symbol _PipeInt_ : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortInt; // TODO

symbol _%Int_ : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortInt; // TODO

symbol _And-Int_ : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortInt; // TODO

symbol _xorInt_ : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortInt; // TODO

symbol absInt : ╬┤ SortInt Рєњ ╬┤ SortInt; // TODO


symbol  _modInt_ : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortInt; // TODO Check
symbol РЎГ_modInt_ : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ РЎГBool Рєњ ╬┤ SortInt;
rule _modInt_ $x1 $x2 Рєф РЎГ_modInt_ $x1 $x2 РЎГ;
rule РЎГ_modInt_ $I1 $I2 (РЎГinj true) Рєф _%Int_ (_PlusInt_ (_%Int_ $I1 (absInt $I2)) (absInt $I2)) (absInt $I2);
rule РЎГ_modInt_ $I1 $I2 РЎГ Рєф РЎГ_modInt_ $I1 $I2 (РЎГinj (_=Slsh=Int_ $I2 0));


symbol _divInt_ : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortInt; // TODO Check
symbol РЎГ_divInt_ : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ РЎГBool Рєњ ╬┤ SortInt;
rule _divInt_ $x1 $x2 Рєф РЎГ_divInt_ $x1 $x2 РЎГ;
rule РЎГ_divInt_ $I1 $I2 (РЎГinj true) Рєф _SlshInt_ (_-Int_ $I1 (_modInt_ $I1 $I2)) $I2;
rule РЎГ_divInt_ $I1 $I2 РЎГ Рєф РЎГ_divInt_ $I1 $I2 (РЎГinj (_=Slsh=Int_ $I2 0));

// symbol _dividesInt_ : ╬┤ SortInt Рєњ ╬┤ SortInt Рєњ ╬┤ SortBool; // TODO Check
// rule _dividesInt_ $I1 $I2 Рєф _==Int_ (_%Int_ $I2 $I1) 0;

// symbol freshInt_INT : ╬┤ SortInt Рєњ ╬┤ SortInt;
