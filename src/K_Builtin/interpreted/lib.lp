// MAP

symbol SortMap : SortK;
symbol StopMap : ╬┤ SortMap;
symbol _Map_ : ╬┤ SortMap Рєњ ╬┤ SortMap Рєњ ╬┤ SortMap;

rule _Map_ $M      StopMap Рєф $M ;
rule _Map_ StopMap $M      Рєф $M ;


symbol _Pipe->_ : ╬┤ SortKItem Рєњ ╬┤ SortKItem Рєњ ╬┤ SortMap; // Singleton

symbol _in_keys_MAP : ╬┤ SortKItem Рєњ ╬┤ SortMap Рєњ ╬┤ SortBool;
symbol РЎГ_in_keys_Map : ╬┤ SortKItem Рєњ ╬┤ SortMap Рєњ ╬┤ РЎГBool Рєњ ╬┤ РЎГBool Рєњ ╬┤ SortBool;
rule _in_keys_MAP $x1 $x5 Рєф РЎГ_in_keys_Map $x1 $x5 РЎГ РЎГ;

// Empty map
rule РЎГ_in_keys_Map $_0 StopMap _ _ Рєф false;

// Singleton map
rule РЎГ_in_keys_Map $X (_Pipe->_ $Y _) _ _ Рєф _==KItem_ $X $Y;

// Map with at least 2 elements
rule РЎГ_in_keys_Map $X (_Map_ (_Pipe->_ $Y _) $M) (РЎГinj true) _ Рєф _in_keys_MAP $X $M;
rule РЎГ_in_keys_Map $X (_Map_ (_Pipe->_ $Y $_0) $M) РЎГ $y0
 Рєф  РЎГ_in_keys_Map $X (_Map_ (_Pipe->_ $Y $_0) $M) (РЎГinj (notBool_ (_==KItem_ $X $Y))) $y0;

rule РЎГ_in_keys_Map $X (_Map_ (_Pipe->_ $Y _) _) _ (РЎГinj true) Рєф true;
rule РЎГ_in_keys_Map $X (_Map_ (_Pipe->_ $Y $_0) $_1) $y1 РЎГ
 Рєф  РЎГ_in_keys_Map $X (_Map_ (_Pipe->_ $Y $_0) $_1) $y1 (РЎГinj (_==KItem_ $X $Y));



symbol MapColnlookup : ╬┤ SortMap Рєњ ╬┤ SortKItem Рєњ ╬┤ SortKItem;
symbol РЎГlookup_Map : ╬┤ SortKItem Рєњ ╬┤ SortMap Рєњ ╬┤ РЎГBool Рєњ ╬┤ РЎГBool Рєњ ╬┤ SortKItem;
rule MapColnlookup $x1 $x5 Рєф РЎГlookup_Map $x5 $x1 РЎГ РЎГ;

// Singleton map
rule РЎГlookup_Map $X (_Pipe->_ $Y $I) (РЎГinj true) _ Рєф $I;
rule РЎГlookup_Map $X (_Pipe->_ $Y $I) РЎГ $y0
 Рєф  РЎГlookup_Map $X (_Pipe->_ $Y $I) (РЎГinj (_==KItem_ $X $Y)) $y0;

// Map with at least 2 elements
rule РЎГlookup_Map $X (_Map_ (_Pipe->_ $Y $I) _) (РЎГinj true) _ Рєф $I;
rule РЎГlookup_Map $X (_Map_ (_Pipe->_ $Y $I) $M) РЎГ $y0
 Рєф  РЎГlookup_Map $X (_Map_ (_Pipe->_ $Y $I) $M) (РЎГinj (_==KItem_ $X $Y)) $y0;

rule РЎГlookup_Map $X (_Map_ (_Pipe->_ $Y $_0) $M) _ (РЎГinj true) Рєф MapColnlookup $M $X;
rule РЎГlookup_Map $X (_Map_ (_Pipe->_ $Y $_0) $M) $y1 РЎГ
 Рєф  РЎГlookup_Map $X (_Map_ (_Pipe->_ $Y $_0) $M) $y1 (РЎГinj (notBool_ (_==KItem_ $X $Y)));


symbol MapColnupdate : ╬┤ SortMap Рєњ ╬┤ SortKItem Рєњ ╬┤ SortKItem Рєњ ╬┤ SortMap;
//symbol РЎГupdate_tmp : ╬┤ SortKItem Рєњ ╬┤ SortKItem Рєњ ╬┤ SortMap Рєњ ╬┤ РЎГBool Рєњ ╬┤ РЎГBool Рєњ ╬┤ SortKItem Рєњ ╬┤ SortBool Рєњ ╬┤ SortMap;
symbol РЎГupdate_ : ╬┤ SortKItem Рєњ ╬┤ SortKItem Рєњ ╬┤ SortMap Рєњ ╬┤ РЎГBool Рєњ ╬┤ SortMap;
rule MapColnupdate StopMap $X $V Рєф (_Pipe->_ $X $V);
rule MapColnupdate (_Pipe->_ $Y $W) $X $V Рєф РЎГupdate_ $X $V (_Pipe->_ $Y $W) РЎГ;
rule MapColnupdate (_Map_ (_Pipe->_ $Y $W) $M) $X $V Рєф // РЎГupdate_tmp $X $V (_Map_ (_Pipe->_ $Y $W) $M) РЎГ РЎГ $Y (_==KItem_ $X $Y);
  РЎГupdate_ $X $V (_Map_ (_Pipe->_ $Y $W) $M) РЎГ;
//rule РЎГupdate_tmp $X $V (_Map_ (_Pipe->_ $Y $W) $M) РЎГ РЎГ $Y true  Рєф (_Map_ (_Pipe->_ $Y $V) $M);
//rule РЎГupdate_tmp $X $V (_Map_ (_Pipe->_ $Y $W) $M) РЎГ РЎГ $Y false Рєф (_Map_ (_Pipe->_ $Y $W) (РЎГupdate_ $X $V $M РЎГ РЎГ $Y);

// Singleton map
//rule РЎГupdate_ $X $V (_Pipe->_ $Y $W) (РЎГinj true) _ Рєф (_Pipe->_ $Y $W);
//rule РЎГupdate_ $X $V (_Pipe->_ $Y $W)  РЎГ $y0
// Рєф  РЎГupdate_ $X $V (_Pipe->_ $Y $W) (РЎГinj (notBool_ (_==KItem_ $X $Y))) $y0;

rule РЎГupdate_ $X $V (_Pipe->_ $Y $W) РЎГ
 Рєф  РЎГupdate_ $X $V (_Pipe->_ $Y $W) (РЎГinj (_==KItem_ $X $Y));
rule РЎГupdate_ $X $V (_Pipe->_ $Y $W) (РЎГinj true)  Рєф (_Pipe->_ $X $V);
rule РЎГupdate_ $X $V (_Pipe->_ $Y $W) (РЎГinj false) Рєф _Map_ (_Pipe->_ $Y $W) (_Pipe->_ $X $V);

// Map with at least 2 elements
//rule РЎГupdate_ $X $V (_Map_ (_Pipe->_ $Y $W) $M) (РЎГinj true) _ Рєф _Map_ (_Pipe->_ $Y $W) (MapColnupdate $M $X $V);
//rule РЎГupdate_ $X $V (_Map_ (_Pipe->_ $Y $W) $M) РЎГ $y0
// Рєф  РЎГupdate_ $X $V (_Map_ (_Pipe->_ $Y $W) $M) (РЎГinj (notBool_ (_==KItem_ $X $Y))) $y0;

rule РЎГupdate_ $X $V (_Map_ (_Pipe->_ $Y $W) $M) РЎГ
 Рєф  РЎГupdate_ $X $V (_Map_ (_Pipe->_ $Y $W) $M) (РЎГinj (_==KItem_ $X $Y));
rule РЎГupdate_ $X $V (_Map_ (_Pipe->_ $Y $W) $M) (РЎГinj true)  Рєф _Map_ (_Pipe->_ $X $V) $M;
rule РЎГupdate_ $X $V (_Map_ (_Pipe->_ $Y $W) $M) (РЎГinj false) Рєф _Map_ (_Pipe->_ $Y $W) (РЎГupdate_ $X $V $M РЎГ);

