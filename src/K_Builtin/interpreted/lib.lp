// IDENTIFIER

symbol SortId : SortK;

symbol _==Id_ : ╬┤ SortId Рєњ ╬┤ SortId Рєњ ╬┤ SortBool; // TODO

symbol Id2String : ╬┤ SortId Рєњ ╬┤ SortString; // TODO


symbol _==KItem_ : ╬┤ SortKItem Рєњ ╬┤ SortKItem Рєњ ╬┤ SortBool; // TODO

symbol a : ╬┤ SortId ;
symbol x : ╬┤ SortId ;
symbol y : ╬┤ SortId ;
symbol z : ╬┤ SortId ;

rule _==KItem_ (inj a) (inj x) Рєф false;
rule _==KItem_ (inj a) (inj y) Рєф false;
rule _==KItem_ (inj a) (inj z) Рєф false;

rule _==KItem_ (inj x) (inj y) Рєф false;
rule _==KItem_ (inj x) (inj z) Рєф false;
rule _==KItem_ (inj x) (inj a) Рєф false;

rule _==KItem_ (inj y) (inj a) Рєф false;
rule _==KItem_ (inj y) (inj x) Рєф false;
rule _==KItem_ (inj y) (inj z) Рєф false;

rule _==KItem_ (inj z) (inj a) Рєф false;
rule _==KItem_ (inj z) (inj x) Рєф false;
rule _==KItem_ (inj z) (inj y) Рєф false;

rule _==KItem_ (inj a) (inj a) Рєф true;
rule _==KItem_ (inj x) (inj x) Рєф true;
rule _==KItem_ (inj y) (inj y) Рєф true;
rule _==KItem_ (inj z) (inj z) Рєф true;




