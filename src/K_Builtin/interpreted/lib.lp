symbol SortSet : SortK;
symbol StopSet : ╬┤ SortSet;
symbol _Set_ : ╬┤ SortSet Рєњ ╬┤ SortSet Рєњ ╬┤ SortSet;

symbol SetColndifference : ╬┤ SortSet Рєњ ╬┤ SortSet Рєњ ╬┤ SortSet;

symbol SetColnin : ╬┤ SortKItem Рєњ ╬┤ SortSet Рєњ ╬┤ SortBool;

symbol SetItem : ╬┤ SortKItem Рєњ ╬┤ SortSet;

symbol choice_SET : ╬┤ SortSet Рєњ ╬┤ SortKItem;

symbol _PipeSet__SET : ╬┤ SortSet Рєњ ╬┤ SortSet Рєњ ╬┤ SortSet;
rule _PipeSet__SET $S1 $S2 Рєф _Set_ $S1 (SetColndifference $S2 $S1);


